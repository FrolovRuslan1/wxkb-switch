#compdef wxkb-switch

# This is zsh wxkb-switch completion

_arguments -s \
'-h[Display this help message.]'      \
'--help[Display this help message.]'  \
'-v[Print program version.]'          \
'--version[Print program version.]'   \
'-d[Enable debug mode.]'              \
'--debug[Enable debug mode.]'         \
'-g[Force execution under GNOME.]'    \
'--gnome[Force execution under GNOME.]'\
'-p[Set previous xkb layout.]'        \
'--prev[Set previous xkb layout.]'    \
'-n[Set next xkb layout.]'            \
'--next[Set next xkb layout.]'        \
'-l[List available layouts.]'         \
'--list[List available layouts.]'